{
  "name": "@bilalshareef/jy",
  "description": "Convert between JSON and YAML formats",
  "version": "1.0.0",
  "author": "Mohammed Bilal Shareef",
  "bin": {
    "jy": "bin/run.js"
  },
  "bugs": "https://github.com/bilalshareef/jy/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "husky": "^9.1.7",
    "mocha": "^11",
    "oclif": "^4",
    "prettier": "^3",
    "shx": "^0.3.3",
    "tsx": "^4.22.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "./bin",
    "./lib",
    "./oclif.manifest.json"
  ],
  "homepage": "https://bilalshareef.github.io/jy/",
  "keywords": [
    "json",
    "yaml",
    "converter",
    "cli",
    "oclif"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "type": "module",
  "oclif": {
    "bin": "jy",
    "dirname": "jy",
    "commands": {
      "strategy": "single",
      "target": "./lib/commands/index.js"
    },
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "update": {
      "node": {
        "version": "22.16.0",
        "targets": [
          "linux-x64",
          "linux-arm64",
          "darwin-x64",
          "darwin-arm64",
          "win32-x64"
        ]
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bilalshareef/jy.git"
  },
  "scripts": {
    "build": "tsc -b",
    "build:clean": "shx rm -rf lib tsconfig.tsbuildinfo && tsc -b",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint",
    "pack:tarballs": "shx rm -rf dist && npm run build:clean && npx oclif pack tarballs",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint && npm run format:check",
    "prepare": "husky",
    "prepack": "oclif manifest",
    "test": "mocha --forbid-only \"test/**/*.test.ts\""
  },
  "types": "lib/index.d.ts"
}
