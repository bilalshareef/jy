{
  "name": "jy",
  "description": "Convert between JSON and YAML formats",
  "version": "0.0.0",
  "author": "Mohammed Bilal Shareef",
  "bin": {
    "jy": "./bin/run.js"
  },
  "bugs": "https://github.com/bilalshareef/jy/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "husky": "^9.1.7",
    "mocha": "^11",
    "oclif": "^4",
    "prettier": "^3",
    "shx": "^0.3.3",
    "tsx": "^4.22.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/bilalshareef/jy",
  "keywords": [
    "json",
    "yaml",
    "converter",
    "cli",
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "jy",
    "dirname": "jy",
    "commands": {
      "strategy": "single",
      "target": "./dist/commands/index.js"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " "
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bilalshareef/jy.git"
  },
  "scripts": {
    "build": "tsc -b",
    "build:clean": "shx rm -rf dist tsconfig.tsbuildinfo && tsc -b",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint && npm run format:check",
    "prepare": "husky",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
